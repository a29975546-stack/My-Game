# Telegram bot token from @BotFather
BOT_TOKEN=123456:REPLACE_ME

# Public HTTPS URL of this server, for example https://your-server.com
PUBLIC_URL=https://your-server.com

# Optional: restrict Mini App origin, comma-separated
ALLOWED_ORIGINS=*

# Server port
PORT=3000

# Optional support link shown in /support or /paysupport replies
SUPPORT_URL=https://t.me/your_support_username
